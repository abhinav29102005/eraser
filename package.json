{
  "name": "lumo",
  "version": "1.0.0",
  "description": "Real-time collaborative whiteboarding app with AI features",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:all": "concurrently \"npm run dev --workspace=frontend\" \"python -m uvicorn main:app --reload --workspace=backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload",
    "build:frontend": "npm run build --workspace=frontend",
    "docker:up": "cd backend && docker-compose up",
    "docker:down": "cd backend && docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
